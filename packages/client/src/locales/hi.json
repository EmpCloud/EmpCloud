    "moduleOffline": "\u092e\u0949\u0921\u094d\u092f\u0942\u0932 \u0911\u092b\u093c\u0932\u093e\u0907\u0928",
    "yourModules": "\u0906\u092a\u0915\u0947 \u092e\u0949\u0921\u094d\u092f\u0942\u0932",
    "coreHRMS": "\u0915\u094b\u0930 HRMS",
    "coreHRMSName": "EMP Cloud \u2014 \u0915\u094b\u0930 HRMS",
    "coreHRMSDescription": "\u0906\u092a\u0915\u093e \u0938\u0902\u092a\u0942\u0930\u094d\u0923 HR \u092a\u094d\u0930\u092c\u0902\u0927\u0928 \u092a\u094d\u0932\u0947\u091f\u092b\u093c\u0949\u0930\u094d\u092e\u0964 \u0915\u0930\u094d\u092e\u091a\u093e\u0930\u0940 \u092a\u094d\u0930\u094b\u092b\u093c\u093e\u0907\u0932 \u092a\u094d\u0930\u092c\u0902\u0927\u093f\u0924 \u0915\u0930\u0947\u0902, \u0936\u093f\u092b\u094d\u091f \u0914\u0930 \u091c\u093f\u092f\u094b-\u092b\u0947\u0902\u0938\u093f\u0902\u0917 \u0915\u0947 \u0938\u093e\u0925 \u0909\u092a\u0938\u094d\u0925\u093f\u0924\u093f \u091f\u094d\u0930\u0948\u0915 \u0915\u0930\u0947\u0902, \u092c\u0939\u0941-\u0938\u094d\u0924\u0930\u0940\u092f \u0905\u0928\u0941\u092e\u094b\u0926\u0928\u094b\u0902 \u0915\u0947 \u0938\u093e\u0925 \u091b\u0941\u091f\u094d\u091f\u0940 \u0906\u0935\u0947\u0926\u0928\u094b\u0902 \u0915\u094b \u0938\u0902\u092d\u093e\u0932\u0947\u0902, \u0938\u092e\u093e\u092a\u094d\u0924\u093f \u091f\u094d\u0930\u0948\u0915\u093f\u0902\u0917 \u0915\u0947 \u0938\u093e\u0925 \u0915\u0930\u094d\u092e\u091a\u093e\u0930\u0940 \u0926\u0938\u094d\u0924\u093e\u0935\u0947\u091c\u093c \u0935\u094d\u092f\u0935\u0938\u094d\u0925\u093f\u0924 \u0915\u0930\u0947\u0902, \u0915\u0902\u092a\u0928\u0940-\u0935\u094d\u092f\u093e\u092a\u0940 \u0918\u094b\u0937\u0923\u093e\u090f\u0901 \u092a\u094d\u0930\u0915\u093e\u0936\u093f\u0924 \u0915\u0930\u0947\u0902, \u0914\u0930 \u0938\u094d\u0935\u0940\u0915\u0943\u0924\u093f \u091f\u094d\u0930\u0948\u0915\u093f\u0902\u0917 \u0915\u0947 \u0938\u093e\u0925 \u0928\u0940\u0924\u093f\u092f\u094b\u0902 \u0915\u093e \u092a\u094d\u0930\u092c\u0902\u0927\u0928 \u0915\u0930\u0947\u0902\u0964 \u0906\u092a\u0915\u0940 EMP Cloud \u0938\u0926\u0938\u094d\u092f\u0924\u093e \u0915\u0947 \u0938\u093e\u0925 \u0938\u092d\u0940 \u092e\u0941\u092b\u094d\u0924 \u092e\u0947\u0902 \u0936\u093e\u092e\u093f\u0932\u0964",
