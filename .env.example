# =============================================================================
# EMP CLOUD — Environment Configuration
# Copy this file to .env and fill in the values.
# =============================================================================

# ---- Server ----
NODE_ENV=development
PORT=3000
BASE_URL=http://localhost:3000

# ---- Database (EmpCloud master) ----
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=secret
DB_NAME=empcloud
DB_AUTO_MIGRATE=true

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ---- OAuth2 / JWT (RS256) ----
# Generate keys with: pnpm generate-keys
RSA_PRIVATE_KEY_PATH=./keys/private.pem
RSA_PUBLIC_KEY_PATH=./keys/public.pem
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d
AUTH_CODE_EXPIRY=10m
ID_TOKEN_EXPIRY=1h

# ---- CORS ----
# Comma-separated list of allowed origins (sub-module URLs)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176

# ---- Email (SendGrid) ----
# Leave SENDGRID_API_KEY blank to disable email sending (dev mode — each
# send is logged instead of hitting the API).
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@empcloud.com
SENDGRID_FROM_NAME=EMP Cloud
# Public URL of the client app — used to build password-reset and
# invitation links. Falls back to BASE_URL if not set.
APP_URL=http://localhost:5173

# ---- Rate Limiting ----
RATE_LIMIT_AUTH_MAX=20
RATE_LIMIT_AUTH_WINDOW_MS=900000
RATE_LIMIT_API_MAX=100
RATE_LIMIT_API_WINDOW_MS=60000

# ---- Billing Integration ----
# Base URL of the EMP Billing module API
BILLING_MODULE_URL=http://localhost:4001
BILLING_API_KEY=

# ---- Logging ----
LOG_LEVEL=debug
LOG_FORMAT=pretty
